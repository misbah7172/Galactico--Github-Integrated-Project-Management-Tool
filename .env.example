# ===========================================
# GITHUB OAUTH CONFIGURATION
# ===========================================

# GitHub OAuth Application credentials
# Create at: https://github.com/settings/developers > OAuth Apps
# Homepage URL:      http://localhost:5000
# Callback URL:      http://localhost:5000/login/oauth2/code/github
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ===========================================
# APPLICATION URLS
# ===========================================

# For local Docker development:
BASE_URL=http://localhost:5000
OAUTH_REDIRECT_URI=http://localhost:5000/login/oauth2/code/github

# For Azure App Service deployment, set these to your Azure URL:
# BASE_URL=https://your-app-name.azurewebsites.net
# OAUTH_REDIRECT_URI=https://your-app-name.azurewebsites.net/login/oauth2/code/github

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# JWT Secret (minimum 32 characters, use a random value)
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_required

# Encryption Key (exactly 32 characters)
ENCRYPTION_KEY=your_encryption_key_32_chars_here

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# These values are used by both docker-compose and the Spring Boot app.
# The postgres container uses DB_NAME/DB_USERNAME/DB_PASSWORD to init the database.
# The app connects via DB_URL.
DB_NAME=galactico
DB_USERNAME=galactico
DB_PASSWORD=change_this_password

# DB_URL is only needed when connecting to an external/cloud database.
# When using docker-compose locally, the app connects via the service name.
# DB_URL=jdbc:postgresql://your-cloud-db-host:5432/galactico

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================

# Used for team invitation emails. Leave blank to disable.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password
